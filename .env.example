# Secrets
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
GROQ_API_KEY_9=
GROQ_API_KEY_10=
# Hoặc dùng một biến duy nhất, phân tách bằng dấu phẩy:
GROQ_API_KEYS=
QWEN_API_KEY=
HF_TOKEN=
QDRANT_API_KEY=

# LLM
LLM_BACKEND=endpoint
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT=120
GROQ_RETRY_ATTEMPTS=4
GROQ_RETRY_DELAY=5
LLM_ENDPOINT_URL=https://tutran27dut--qwen2-5-14b-vllm-serve.modal.run
LLM_ENDPOINT_MODEL=qwen2.5-14b-instruct
LLM_ENDPOINT_TIMEOUT=600
LOCAL_LLM_MODEL=Qwen/Qwen3-4B-Instruct-2507
LOCAL_LLM_MAX_MODEL_LEN=
LOCAL_LLM_LOAD_IN_4BIT=true

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal_agent_rag_harrier_idf
QDRANT_TIMEOUT=120
QDRANT_HNSW_EF=64

# Models
DENSE_MODEL=mainguyen9/vietlegal-harrier-0.6b
COLBERT_MODEL=BAAI/bge-m3
DENSE_DIM=1024
NORMALIZE_DENSE=true

# Retrieval
TOP_N=50
TOP_K=6
BATCH_SIZE=128
RETRIEVAL_TOP_K=30
INITIAL_FUSION_TOP_K=30
FINAL_TOP_K=6

# Rerank
ENABLE_COLBERT=true
ENABLE_CROSS_ENCODER=true
RERANK_DEVICE=cuda
COLBERT_BATCH_SIZE=16
CROSS_ENCODER_BATCH_SIZE=16
COLBERT_TOP_K=15
CROSS_ENCODER_TOP_K=8
RERANK_MAX_CHARS=1000
CROSS_ENCODER_MODEL=Qwen/Qwen3-Reranker-0.6B

# Graph / context
GRAPH_PATH=data/indexes/graph/legal_graph.pkl
PRELOAD_GRAPH=true
GRAPH_SEED_TOP_K=5
GRAPH_TOP_K=10
CONTEXT_TOP_K=10

# Ingest / upload
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_UPLOAD_WORKERS=4
HF_DOWNLOAD_WORKERS=8
STORE_TEXT=true
